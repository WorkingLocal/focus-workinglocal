# Copy to kiosk-server/.env and fill in values

# Public base URL (no trailing slash)
# Leave empty for local-only mode (URL auto-detected from LAN IP)
PUBLIC_URL=https://focus.workinglocal.be

# Operator secret — required when server is publicly reachable
# Open kiosk UI at: https://focus.workinglocal.be/?key=<this-value>
# Leave empty to disable auth (local LAN only)
OPERATOR_SECRET=change-me-to-a-strong-random-secret

# Server port (default: 3000)
PORT=3000
